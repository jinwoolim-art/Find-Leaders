# ──────────────────────────────────────────────
# Server
# ──────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ──────────────────────────────────────────────
# Kakao Developers (https://developers.kakao.com)
# ──────────────────────────────────────────────
# 내 애플리케이션 > 앱 키 > REST API 키
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here
# 카카오 로그인 > 보안 (선택, ON 했다면 입력)
KAKAO_CLIENT_SECRET=
# 카카오 로그인 > Redirect URI (콘솔 등록값과 정확히 일치해야 함)
KAKAO_REDIRECT_URI=http://localhost:5500/test/test-client.html

# ──────────────────────────────────────────────
# Sign in with Apple (https://developer.apple.com/account)
# 발급 위치는 docs/apple-login-handoff.md 의 "Apple 콘솔 체크리스트" 참고
# ──────────────────────────────────────────────
# Membership > Team ID (계정 우상단 10자리)
APPLE_TEAM_ID=your_apple_team_id
# Certificates, Identifiers & Profiles > Keys > 생성한 Key 의 Key ID
APPLE_KEY_ID=your_apple_key_id
# 다운로드한 .p8 키 파일 경로 (이 방식 권장 — git 에는 커밋 금지)
APPLE_PRIVATE_KEY_PATH=./secrets/AuthKey.p8
# 또는 파일 대신 인라인으로 (줄바꿈은 \n 으로). PATH 가 있으면 PATH 우선.
APPLE_PRIVATE_KEY=
# 네이티브 iOS 앱의 Bundle ID (App ID). 네이티브 id_token 의 aud.
APPLE_BUNDLE_ID=ir.thisishilo.app
# 웹 로그인용 Services ID. 웹 id_token 의 aud / 웹 code 교환 시 client_id.
APPLE_SERVICES_ID=ir.thisishilo.web
# 웹 code 교환 시 redirect URI (콘솔 등록값과 정확히 일치). 네이티브만 쓰면 비워둠.
APPLE_REDIRECT_URI=

# ──────────────────────────────────────────────
# JWT (모두 충분히 긴 무작위 문자열로 교체)
# 추천: openssl rand -base64 48
# ──────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_me_with_a_long_random_string_access
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_SECRET=replace_me_with_a_long_random_string_refresh
JWT_REFRESH_EXPIRES_IN=14d
JWT_SIGNUP_SECRET=replace_me_with_a_long_random_string_signup
JWT_SIGNUP_EXPIRES_IN=10m

# ──────────────────────────────────────────────
# Database
# DB_TYPE: 'sqlite' (로컬 테스트) | 'postgres' (운영)
# ──────────────────────────────────────────────
DB_TYPE=sqlite

# SQLite 사용 시
DB_FILE=./data/dev.sqlite

# PostgreSQL 사용 시 (DB_TYPE=postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=ilkkun
DB_PASSWORD=change_me
DB_DATABASE=ilkkun_dev

# 개발에서만 true. 운영은 false + 마이그레이션 사용
DB_SYNCHRONIZE=true
